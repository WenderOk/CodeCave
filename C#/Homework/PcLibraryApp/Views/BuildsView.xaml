<UserControl x:Class="PcLibraryApp.Views.BuildsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PcLibraryApp.Views" 
             mc:Ignorable="d" 
             xmlns:viewmodels="clr-namespace:PcLibraryApp.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:BuildsViewModel}"
             d:DesignHeight="450" d:DesignWidth="800"
             Padding="20">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource ContentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ: Таблица сохраненных сборок -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Сохраненные сборки" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource TextDarkBrush}"/>

            <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding SavedBuilds}" 
                      SelectedItem="{Binding SelectedBuild}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название ПК" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalPrice, StringFormat={}{0:N0} руб.}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
                <Button Content="Удалить сборку" 
                        Command="{Binding DeleteBuildCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="10"/>
                <Button Content="Редактировать сборку" 
                        Command="{Binding EditBuildCommand}"
                        Style="{StaticResource MenuButtonStyle}"
                        Background="#555555"
                        Margin="10"/>
            </StackPanel>
        </Grid>

        <!-- ПРАВАЯ ЧАСТЬ: Детальный состав ПК -->
        <Border Grid.Column="1" Background="White" Padding="20" CornerRadius="4" Margin="10,0,0,0">
            <Grid>
                <TextBlock Text="Выберите сборку из списка слева для просмотра состава" 
                   Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedBuild}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <DockPanel>
                    <DockPanel.Style>
                        <Style TargetType="DockPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedBuild}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DockPanel.Style>

                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                        <TextBlock Text="{Binding SelectedBuild.Name}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentButtonBrush}"/>
                        <Separator Margin="0,10,0,10" Background="#E0E0E0"/>
                        <TextBlock Text="Установленные комплектующие:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    </StackPanel>

                    <ListView ItemsSource="{Binding SelectedBuild.Components}" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="5,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Category}" FontWeight="Bold" Foreground="#777777"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FullName}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat={}{0:N0} р.}" HorizontalAlignment="Right" Foreground="#43A047"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
