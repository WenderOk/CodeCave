<UserControl x:Class="PcLibraryApp.Views.CatalogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PcLibraryApp.Views" 
        xmlns:viewmodels="clr-namespace:PcLibraryApp.ViewModels" 
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:CatalogViewModel}"
        d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="{StaticResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="0" Background="White" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск компонента:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox Grid.Column="1" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBoxStyle}"/>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Grid.Row="1" Margin="15,0,15,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" 
                      ItemsSource="{Binding ComponentsView}" 
                      SelectedItem="{Binding SelectedComponent}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="100"/>
                    <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="130"/>
                    <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="*"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Цена (руб.)" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Удалить" 
                        Command="{Binding DeleteComponentCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="0,0,10,0"/>

                <Button Content="Редактировать" 
                        Command="{Binding EditComponentCommand}"
                        Style="{StaticResource MenuButtonStyle}"
                        Background="#555555"
                        Margin="0,0,10,0"
                        Padding="15,8"
                        FontWeight="Bold"/>

                <Button Content="Добавить" 
                        Command="{Binding AddComponentCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
