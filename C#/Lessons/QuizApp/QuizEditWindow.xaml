<Window x:Class="QuizApp.QuizEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuizApp"
        mc:Ignorable="d"
        Title="QuizEditWindow" Height="650" Width="800">
    <DockPanel>
        <TextBox Text="" DockPanel.Dock="Top" Height="70"/>
        <StackPanel DockPanel.Dock="Bottom">
            <Button Content="Удалить вопрос"/>
            <Button Content="Добавить вопрос"/>
            <Button Content="Сохранить изменения"/>
            
        </StackPanel>
        <Button Content="←" DockPanel.Dock="Left" FontSize="20"/>
        <Button Content="→" DockPanel.Dock="Right" FontSize="20"/>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBox Text=""/>
                <TextBox Text=""/>
            </StackPanel>
            <ItemsControl>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </DockPanel>
</Window>
