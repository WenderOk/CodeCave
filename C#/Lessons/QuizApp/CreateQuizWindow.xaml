<Window x:Class="QuizApp.CreateQuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuizApp.ViewModel"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:CreateQuizViewModel, IsDesignTimeCreatable=True}"
      
        Title="CreateQuizWindow" Height="550" Width="800">
    <StackPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
            <Label Content="Название викторины" Margin="10"/>
            <TextBox Width="635" Margin="10" Text="{Binding QuizName}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal">
            <StackPanel>
                <Label Content="Вопрос"/>
                <TextBox Margin="10" Text="{Binding CurrentQuestion.Id}"/>
            </StackPanel>
            <TextBox Width="560" Margin="10" Text="{Binding CurrentQuestion.Text}"/>
            <Label Content="Правильность ответа "/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Height="200">
            <Label Content="Варианты ответа" Margin="10"/>
            <ItemsControl ItemsSource="{Binding CurrentQuestion.Answers}" Width="640">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Text="{Binding Text}" />

                            <CheckBox Grid.Column="1" HorizontalAlignment="Center"
                          IsChecked="{Binding IsCorrect}" />
                        </Grid>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Orientation="Vertical">
            <Button Content="Добавить вариант ответа" Margin="10" Command="{Binding AddAnswerCommand}"/>
            <Button Content="Добавить Сохранить и перейти к созданию следующего вопроса" Margin="10" Command="{Binding SaveQuestionCommand}"/>
            <Button Content="Завершить добавления вопросов" Margin="10" Command="{Binding FinishQuizCommand}"/>
        </StackPanel>   
    </StackPanel>

</Window>
