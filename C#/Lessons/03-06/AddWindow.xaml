<Window x:Class="_03_06.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_03_06"
        mc:Ignorable="d"
        Title="AddWindow" Height="450" Width="800" Name="AddContact">
    <StackPanel>
        <Label Content="Имя" FontSize="16"/>
        <TextBox Text="{Binding TextBoxName}"/>
        <Label Content="Email" FontSize="16"/>
        <TextBox Text="{Binding TextBoxEmail}"/>
        <Label Content="Телефон" FontSize="16"/>
        <TextBox Text="{Binding TextBoxPhone}"/>

        <Button Content="Добавить" Margin="0,15" Command="{Binding AddContactCommand}" CommandParameter="{Binding ElementName=AddContact}"/>


    </StackPanel>

    
</Window>
