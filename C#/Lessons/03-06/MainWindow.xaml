<Window x:Class="_03_06.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_03_06"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <Label DockPanel.Dock="Top" 
               Content="Приложение управления контактами"
               FontSize="20"
               HorizontalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Bottom">
            <Button Content="Add" FontSize="16" Command="{Binding OpenAddContactCommand}"/>
            <Button Content="Edit" FontSize="16" Command="{Binding OpenAddContactCommand}"/>
            <Button Content="Remove" FontSize="16" Command="{Binding OpenAddContactCommand}"/>
        </StackPanel>

        <StackPanel>
            <DataGrid ItemsSource="{Binding Contacts}"/>
        </StackPanel>
    </DockPanel>
</Window>
