<Window x:Class="_28_05_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_28_05_1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="50"/>
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="Green" />
            <Setter Property="FontSize" Value="25" />
        </Style>
    </Window.Resources>
    <StackPanel Orientation="Vertical">
        <TextBox Name="textBox_pwd" FontSize="24" Height="40"/>
        <Slider Name="slider_len" Value="0" Minimum="3" Maximum="20" SelectionStart="0" Height="30" 
                IsSelectionRangeEnabled="True"/>

        <StackPanel Orientation="Horizontal">
            <Label FontSize="24" Content="Длина пароля = "/>
            <TextBox Name="textBox_len" Width="600"
                     Text="{Binding ElementName=slider_len, Path=Value, StringFormat={}{0:F0}}"/>
        </StackPanel>

        <CheckBox Name="checkBox_letters" FontSize="24" Content="Буквы"/>
        <CheckBox Name="checkBox_digits" FontSize="24" Content="Цифры"/>
        <CheckBox Name="checkBox_spec" FontSize="24" Content="Спец символы"/>

        <Button FontSize="24" Margin="10" Content="Сгенерировать" Style="{StaticResource ButtonStyle}" Click="BtnGenerate_Click"/>
        <Button FontSize="24" Margin="10" Content="Сброс" Style="{StaticResource ButtonStyle}" Click="BtnReset_Click"/>

    </StackPanel>
</Window>
