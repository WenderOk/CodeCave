<Window x:Class="_28_05.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_28_05"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid x:Name="MainRoot">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBox Grid.Row="0" Grid.Column="0" FontSize="30" Text="Hello" x:Name="textLabel" Grid.ColumnSpan="4"/>

        <Button Grid.Row="1" Grid.Column="0" FontSize="32" Content="1" BorderBrush="Green"/>
        <Button Grid.Row="1" Grid.Column="1" FontSize="32" Content="2" BorderBrush="Green"/>
        <Button Grid.Row="1" Grid.Column="2" FontSize="32" Content="3" BorderBrush="Green"/>
        <Button Grid.Row="1" Grid.Column="3" FontSize="32" Content="+" BorderBrush="Green"/>

        <Button Grid.Row="2" Grid.Column="0" FontSize="32" Content="4" BorderBrush="Green"/>
        <Button Grid.Row="2" Grid.Column="1" FontSize="32" Content="5" BorderBrush="Green"/>
        <Button Grid.Row="2" Grid.Column="2" FontSize="32" Content="6" BorderBrush="Green"/>
        <Button Grid.Row="2" Grid.Column="3" FontSize="32" Content="-" BorderBrush="Green"/>

        <Button Grid.Row="3" Grid.Column="0" FontSize="32" Content="7" BorderBrush="Green"/>
        <Button Grid.Row="3" Grid.Column="1" FontSize="32" Content="8" BorderBrush="Green"/>
        <Button Grid.Row="3" Grid.Column="2" FontSize="32" Content="9" BorderBrush="Green"/>
        <Button Grid.Row="3" Grid.Column="3" FontSize="32" Content="*" BorderBrush="Green"/>

        <Button Grid.Row="4" Grid.Column="0" FontSize="32" Content="0" BorderBrush="Green"/>
        <Button Grid.Row="4" Grid.Column="1" FontSize="32" Content="AC" BorderBrush="Green"/>
        <Button Grid.Row="4" Grid.Column="2" FontSize="32" Content="=" BorderBrush="Green"/>
        <Button Grid.Row="4" Grid.Column="3" FontSize="32" Content="/" BorderBrush="Green"/>

    </Grid>
</Window>
