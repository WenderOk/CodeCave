<Window x:Class="_01_06.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_01_06"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:ContactManager, IsDesignTimeCreatable=True}"
        Title="MainWindow" Height="450" Width="800"
        Closing="Window_Closing" Deactivated="Window_Deactivated">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30*"/>
            <ColumnDefinition Width="30*"/>
            <ColumnDefinition Width="30*"/>
        </Grid.ColumnDefinitions>
        <DataGrid ItemsSource="{Binding Contacts}"
                  Name="ContactsDataGrid"
                  AutoGenerateColumns="False"
                  SelectedCellsChanged="ContactsDataGrid_SelectedCellsChanged"
                  Grid.ColumnSpan="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="2">
            <Label Content="Name"/>
            <TextBox Name="TextBox_name"/>
            <Label Content="Phone"/>
            <TextBox Name="TextBox_phone"/>
            <Label Content="Email"/>
            <TextBox Name="TextBox_email"/>
            <Button Content="Add" Name="Button_add" Margin="0 15" Click="Button_add_Click"/>
            <Button Content="Remove" Name="Button_remove" Margin="0 15" Click="Button_remove_Click"/>
            <Button Content="Edit" Name="Button_edit" Margin="0 15" Click="Button_edit_Click"/>    

        
        </StackPanel>
                    
    </Grid>
</Window>
