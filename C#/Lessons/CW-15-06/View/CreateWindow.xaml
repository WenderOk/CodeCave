<Window x:Class="CW_15_06.View.CreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CW_15_06.View"
        xmlns:vm="clr-namespace:CW_15_06.ViewModel"
        mc:Ignorable="d"
        Title="CreateWindow" Height="600" Width="1000">
    <Window.DataContext>
        <vm:CreateViewModel/>
    </Window.DataContext>
    <DockPanel>
        <Label Content="Создание записи" HorizontalAlignment="Center" FontSize="20" DockPanel.Dock="Top"/>
        <StackPanel DockPanel.Dock="Bottom">
            <Button Content="Сохранить запись" Margin="5"/>
            <Button Content="Выйти в главное меню" Margin="5" Command="{Binding ReturnToMainCommand}" Click="Button_Click"/>
        </StackPanel>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="70*"/>
                <ColumnDefinition Width="30*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="ID"/>
            <TextBox Grid.Row="0" Grid.Column="1" Margin="5" Text=""/>
            <Label Grid.Row="1" Grid.Column="0" Content="Объект"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="10"
                      ItemsSource="{Binding Objects}"
                      DisplayMemberPath="Name"/>
            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Vertical">
                <TextBox Height="25" Margin="5" ToolTip="Поле для нового объекта" Text="{Binding NewObject}"/>
                <Button Height="25" Margin="5" Content="Добавить новый объект" Command="{Binding AddObjectCommand}"/>
            </StackPanel>
            <Label Grid.Row="2" Grid.Column="0" Content="Дата"/>
            <TextBox Grid.Row="2" Grid.Column="1" Margin="5" Text=""/>

            <Label Grid.Row="3" Grid.Column="0" Content="Классификация"/>
            <ComboBox Grid.Row="3" Grid.Column="1" Margin="10"
                      ItemsSource="{Binding Classifications}"
                      DisplayMemberPath="ClassName"/>
            <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Vertical">
                <TextBox Height="25" Margin="5" ToolTip="Поле для новой классификации" Text="{Binding NewClassification}"/>
                <Button Height="25" Margin="5" Content="Добавить новую классификацию" Command="{Binding AddClassificationCommand}"/>
            </StackPanel>

            <Label Grid.Row="4" Grid.Column="0" Content="Текст наблюдения"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text=""/>

            <Label Grid.Row="5" Grid.Column="0" Content="Рейтинг"/>
            <ComboBox Grid.Row="5" Grid.Column="1" Margin="5" 
                      ItemsSource="{Binding Ratings}"
                      DisplayMemberPath="Value"/>
        </Grid>
    </DockPanel>
</Window>
